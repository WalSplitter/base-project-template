{
  "name": "base-project-template",
  "version": "1.0.0",
  "description": "Professional, production-ready template for modern applications with best practices and GitHub Copilot optimization",
  "license": "MIT",
  "author": "WalSplitter",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/base-project-template"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "workspaces": [
    "web",
    "apps/*",
    "desktop/*",
    "tools/*",
    "shared/*"
  ],
  "scripts": {
    "install-all": "npm install",
    "dev": "npm run dev --workspaces",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:watch": "npm run test:watch --workspaces",
    "test:coverage": "npm run test:coverage --workspaces",
    "lint": "npm run lint -w web -w apps/api -w shared/types",
    "lint:fix": "npm run lint:fix --workspaces",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "npm run clean --workspaces && npm run clean-root",
    "clean-root": "rimraf node_modules package-lock.json",
    "type-check": "npm run type-check --workspaces",
    "type-check:watch": "npm run type-check:watch --workspaces",
    "precommit": "npm run lint && npm run type-check && npm run format:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "npm@9.0.0"
}
